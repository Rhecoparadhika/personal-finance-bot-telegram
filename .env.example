# ===== Telegram =====
BOT_TOKEN=123456:ABC-your-telegram-bot-token
# Public HTTPS base url of your deployment (Railway gives you one), no trailing slash
BASE_URL=https://your-app.up.railway.app
# Secret path segment for the webhook, keep it random
WEBHOOK_SECRET=change-me-to-a-random-string

# ===== LLM Providers (set the ones you use; LLM_PROVIDER picks the active one) =====
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-ant-....
CLAUDE_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Model names (override if you like)
OPENAI_MODEL=gpt-5.4-nano
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-1.5-flash

# ===== Google Sheets — via Apps Script Web App (NO service account, NO API key) =====
# 1. Open your spreadsheet -> Extensions -> Apps Script -> paste google-apps-script/Code.gs
# 2. Set a SHARED_SECRET script property (any random string) — see README
# 3. Deploy -> New deployment -> Web app -> Execute as: Me, Who has access: Anyone
# 4. Paste the resulting /exec URL below, and the same secret you set in step 2
GAS_WEB_APP_URL=
GAS_DEPLOYMENT_ID=
GAS_SHARED_SECRET=financial-bot-demo

# ===== App =====
PORT=8000
TIMEZONE=Asia/Jakarta
DEFAULT_CURRENCY=IDR
LOG_LEVEL=INFO
ENVIRONMENT=production
